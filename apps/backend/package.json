{
  "name": "@accountly/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:evals": "vitest run --config vitest.evals.config.ts",
    "parse": "tsx scripts/parse-pdf.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:rollback": "tsx scripts/migrate.ts down",
    "db:reset": "tsx scripts/migrate.ts reset",
    "db:codegen": "tsx scripts/codegen.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@hono/zod-validator": "^0.8.0",
    "ai": "^6.0.193",
    "better-auth": "^1.6.11",
    "hono": "^4.7.4",
    "kysely": "^0.28.17",
    "pg": "^8.21.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250519.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "kysely-codegen": "^0.20.0",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.7",
    "wrangler": "^3.90.0"
  }
}
