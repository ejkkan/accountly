# Copy to .dev.vars (gitignored). Local dev defaults — production secrets
# live in Cloudflare Worker / Vercel env, not here.

# Local Postgres (Docker) — boots automatically as part of `pnpm dev`.
DATABASE_URL=postgres://accountly:accountly@127.0.0.1:5433/accountly
DATABASE_URL_DIRECT=postgres://accountly:accountly@127.0.0.1:5433/accountly

# better-auth — any random hex string works locally (`openssl rand -hex 32`).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787
APP_URL=http://localhost:5001

# Anthropic — used by the `ai` SDK for invoice → journal entry.
ANTHROPIC_API_KEY=
