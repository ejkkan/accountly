# Copy to .env.local (gitignored) for production-shaped local runs.
# Both vars have defaults that work for `pnpm dev` without copying this file.

# Where Next's server-side code (proxy.ts, RSC fetches) reaches the Worker.
# Defaults to http://localhost:8787 when unset — only override for staging /
# prod where the Worker isn't on localhost.
# BACKEND_URL=https://accountly-backend.your-account.workers.dev

# Browser origin used by the better-auth client during server-side rendering
# (window.location.origin handles the client side). Required in production
# because better-auth parses the value with `new URL()` — a bare path won't
# do. Defaults to http://localhost:5001 when unset.
# NEXT_PUBLIC_APP_URL=https://accountly.example.com
