{
  "name": "accountly",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "docker compose -f apps/backend/docker-compose.yml up -d --wait && pnpm --filter @accountly/backend db:migrate && pnpm --filter @accountly/backend db:codegen && pnpm -r --parallel --stream dev",
    "dev:web": "pnpm --filter web dev",
    "dev:backend": "pnpm --filter @accountly/backend dev",
    "db:up": "docker compose -f apps/backend/docker-compose.yml up -d --wait",
    "db:down": "docker compose -f apps/backend/docker-compose.yml down",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm format:check"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.12.3"
}
